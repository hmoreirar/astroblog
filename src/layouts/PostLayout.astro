---
export interface Props {
  title: string;
  date: Date;
  tags: string[];
  cover?: string;
  matrixRain?: boolean;
}
const { title, date, tags, cover, matrixRain } = Astro.props;
import ThemeToggle from '../components/ThemeToggle.astro';
import MatrixRain from '../components/MatrixRain.astro';
import '../styles/global.css';
import { formatDate } from '../utils/dateFormat';
import { getUniqueTags } from '../utils/tags';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | otro.blog.mas</title>
  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
  <link rel="icon" type="image/x-icon" href={`${import.meta.env.BASE_URL}/favicon.ico`} />
  <script is:inline>(function(){var t=localStorage.getItem('theme');if(t==='light'||(!t&&window.matchMedia('(prefers-color-scheme:light)').matches))document.documentElement.classList.add('light')})();</script>
  <link rel="canonical" href={`${Astro.site}${Astro.url.pathname}`} />
  <meta name="description" content={`Artículo sobre ${title} en otro.blog.mas`} />
  <meta property="og:title" content={`${title} | otro.blog.mas`} />
  <meta property="og:description" content={`Artículo sobre ${title} en otro.blog.mas`} />
  <meta property="og:url" content={`${Astro.site}${Astro.url.pathname}`} />
  <meta property="og:type" content="article" />
  {cover && <meta property="og:image" content={`${Astro.site}${import.meta.env.BASE_URL}${cover}`} />}
  <meta property="article:published_time" content={date.toISOString()} />
  <meta property="article:tag" content={tags.join(',')} />
  <meta name="twitter:card" content="summary_large_image" />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "datePublished": date.toISOString(),
    "dateModified": date.toISOString(),
    "author": {
      "@type": "Person",
      "name": "Autor"
    },
    "publisher": {
      "@type": "Organization",
      "name": "otro.blog.mas"
    },
    "url": `${Astro.site}${Astro.url.pathname}`,
    "image": cover ? `${Astro.site}${import.meta.env.BASE_URL}${cover}` : undefined,
    "keywords": tags.join(', ')
  })} />
</head>
<body>
  <a href="#main-content" class="skip-link">Saltar al contenido principal</a>
  <header>
    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:0.5rem">
      <a href={`${import.meta.env.BASE_URL}/`}>← otro.blog.mas</a>
      <ThemeToggle />
    </div>
    <h1>{title}</h1>
    <div class="meta">{date.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}</div>
    <div class="tags">
      {getUniqueTags(tags).map(tag => (
        <a href={`${import.meta.env.BASE_URL}/tags/${tag}/`} class="tag">{tag}</a>
      ))}
    </div>
  </header>
  {matrixRain ? <MatrixRain /> : cover && <img src={`${import.meta.env.BASE_URL}${cover}`} alt={title} class="cover" />}
  <main id="main-content" class="content">
    <slot /><!-- Aquí se inyecta el contenido del post -->
  </main>
</body>
</html>
