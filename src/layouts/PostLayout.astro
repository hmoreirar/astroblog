---
export interface Props {
  title: string;
  date: Date;
  tags: string[];
  cover?: string;
}
const { title, date, tags, cover } = Astro.props;
import '../styles/global.css';
import { formatDate } from '../utils/dateFormat';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Zine Digital</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="canonical" href={`${Astro.site}${Astro.url.pathname}`} />
  <meta name="description" content={`Artículo sobre ${title} en Zine Digital`} />
  <meta property="og:title" content={`${title} | Zine Digital`} />
  <meta property="og:description" content={`Artículo sobre ${title} en Zine Digital`} />
  <meta property="og:url" content={`${Astro.site}${Astro.url.pathname}`} />
  <meta property="og:type" content="article" />
  {cover && <meta property="og:image" content={`${Astro.site}${cover}`} />}
  <meta property="article:published_time" content={date.toISOString()} />
  <meta property="article:tag" content={tags.join(',')} />
  <meta name="twitter:card" content="summary_large_image" />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "datePublished": date.toISOString(),
    "dateModified": date.toISOString(),
    "author": {
      "@type": "Person",
      "name": "Autor"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Zine Digital"
    },
    "url": `${Astro.site}${Astro.url.pathname}`,
    "image": cover ? `${Astro.site}${cover}` : undefined,
    "keywords": tags.join(', ')
  })} />
</head>
<body>
  <a href="#main-content" class="skip-link">Saltar al contenido principal</a>
  <header>
    <a href={`${import.meta.env.BASE_URL}/`}>← Zine Digital</a>
    <h1>{title}</h1>
    <div class="meta">{date.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}</div>
    <div class="tags">
      {tags.map(tag => <span class="tag">{tag}</span>)}
    </div>
  </header>
  {cover && <img src={cover} alt={title} class="cover" />}
  <main id="main-content" class="content">
    <slot /><!-- Aquí se inyecta el contenido del post -->
  </main>
</body>
</html>
